\end{itemize}
}

\frame[containsverbatim]
{
\frametitle{Вычисление значения интерполирующей функции}
Значения многочлена в точке $x=0.15$:
\begin{lstlisting}[firstnumber=last]
>> polyval(p,0.15)
ans = 
      0.48750
\end{lstlisting}      
}

